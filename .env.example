# ─── Solana RPC ───────────────────────────────────────────────────────────────
# Рекомендуємо платний RPC (Helius, QuickNode, Alchemy) для стабільної роботи
RPC_URL=https://api.mainnet-beta.solana.com

# ─── Токени ───────────────────────────────────────────────────────────────────
# Mint адреси токенів для моніторингу
MINT_A=So11111111111111111111111111111111111111112     # Wrapped SOL
MINT_B=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v  # USDC

# Quote токен для розрахунку прибутку (зазвичай = MINT_B)
QUOTE_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ─── Арбітраж ─────────────────────────────────────────────────────────────────
# Інтервал оновлення в мілісекундах (мін: 500)
POLLING_INTERVAL_MS=2000

# Мінімальний чистий прибуток для сигналу (в quote токені, напр. USDC)
MIN_PROFIT_THRESHOLD=0.01

# Розмір симульованої угоди (в quote токені)
TRADE_SIZE=100

# Максимально допустиме прослизання (0.05 = 5%)
MAX_SLIPPAGE_PERCENT=0.05

# Вартість транзакції в quote токені (для розрахунку net profit)
TX_COST_IN_QUOTE=0.0002

# ─── Логування ────────────────────────────────────────────────────────────────
# Рівень логування: error | warn | info | debug
LOG_LEVEL=info

# Записувати логи у файли logs/ (true/false)
LOG_TO_FILE=true

# ─── UI ───────────────────────────────────────────────────────────────────────
# Максимальна кількість можливостей у таблиці
MAX_OPPORTUNITIES_DISPLAY=15

# Показувати slippage в таблиці (true/false)
SHOW_SLIPPAGE=true

# ─── Просунуті налаштування ───────────────────────────────────────────────────
# Максимальна кількість пулів для моніторингу
MAX_POOLS_TO_MONITOR=50

# Кількість спроб при помилці RPC
RPC_RETRIES=3

# Базова затримка між спробами (мс)
RPC_RETRY_DELAY_MS=1000