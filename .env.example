# Solana RPC URL (для mainnet-beta)
RPC_URL=https://api.mainnet-beta.solana.com
# Або використовуйте власний RPC: https://rpc.helius.xyz/?api-key=YOUR_KEY

# Налаштування моніторингу
POLLING_INTERVAL_MS=2000
MIN_PROFIT_THRESHOLD=0.01
TRADE_SIZE=100
MAX_SLIPPAGE_PERCENT=0.05

# Логування
LOG_LEVEL=info
LOG_TO_FILE=true

# Опціонально: конфігурація токенів за замовчуванням
DEFAULT_MINT_A=So11111111111111111111111111111111111111112
DEFAULT_MINT_B=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
DEFAULT_QUOTE_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Витрати на транзакцію (в quote токені)
TX_COST_IN_QUOTE=0.0002