{
    "name": "monitoring-tool",
    "version": "1.0.0",
    "description": "Real-time arbitrage monitoring tool for Raydium CPMM pools on Solana",
    "main": "dist/index.js",
    "type": "commonjs",
    "scripts": {
      "build": "tsc",
      "start": "node dist/index.js",
      "dev": "ts-node src/index.ts",
      "dev:watch": "ts-node-dev --respawn --transpile-only src/index.ts",
      "monitor": "npm run dev -- --",
      "clean": "rimraf dist",
      "type-check": "tsc --noEmit",
      "lint": "eslint src/**/*.ts",
      "format": "prettier --write \"src/**/*.ts\"",
      "test": "jest",
      "test:watch": "jest --watch",
      "prepare": "npm run build"
    },
    "keywords": [
      "solana",
      "raydium",
      "arbitrage",
      "defi",
      "crypto"
    ],
    "author": "btcthirst",
    "license": "MIT",
    "dependencies": {
      "@solana/web3.js": "1.95.0",
      "decimal.js": "^10.5.0",
      "dotenv": "^16.4.7",
      "winston": "^3.17.0",
      "commander": "^13.1.0",
      "chalk": "^5.4.1",
      "cli-table3": "^0.6.5",
      "zod": "^3.24.2"
    },
    "devDependencies": {
      "@types/node": "^22.13.0",
      "typescript": "^5.7.3",
      "ts-node": "^10.9.2",
      "ts-node-dev": "^2.0.0",
      "@typescript-eslint/eslint-plugin": "^8.23.0",
      "@typescript-eslint/parser": "^8.23.0",
      "eslint": "^9.20.0",
      "prettier": "^3.4.2",
      "jest": "^29.7.0",
      "@types/jest": "^29.5.14",
      "ts-jest": "^29.2.5",
      "rimraf": "^6.0.1"
    },
    "engines": {
      "node": ">=20.0.0",
      "npm": ">=10.0.0"
    },
    "repository": {
      "type": "git",
      "url": "https://github.com/btcthirst/monitoring-tool"
    }
  }