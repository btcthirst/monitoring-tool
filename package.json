{
  "name": "monitoring-tool",
  "version": "1.0.0",
  "description": "Real-time arbitrage monitoring tool for Raydium CPMM pools",
  "license": "MIT",
  "author": "Superteam Ukraine",
  "main": "dist/index.js",
  "bin": {
    "raydium-arb-monitor": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "monitor": "ts-node src/index.ts monitor",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@raydium-io/raydium-sdk-v2": "^0.2.41-alpha",
    "@solana/web3.js": "^1.95.4",
    "bn.js": "^5.2.3",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.6",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
