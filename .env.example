# ─── Solana RPC ───────────────────────────────────────────────────────────────
# A private RPC (Helius, QuickNode, Alchemy) is highly recommended for stability
RPC_URL=https://api.mainnet-beta.solana.com

# ─── Tokens ───────────────────────────────────────────────────────────────────
# Token mint addresses to monitor
MINT_A=So11111111111111111111111111111111111111112     # Wrapped SOL
MINT_B=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v  # USDC

# Quote token for profit calculation (usually = MINT_B)
QUOTE_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ─── Arbitrage ────────────────────────────────────────────────────────────────
# Update interval in milliseconds (min: 500)
POLLING_INTERVAL_MS=2000

# Minimum net profit threshold to signal (in quote token units, e.g., USDC)
MIN_PROFIT_THRESHOLD=0.01

# Simulated trade size (in quote token units)
TRADE_SIZE=100

# Maximum allowed slippage (e.g., 0.05 = 5%)
MAX_SLIPPAGE_PERCENT=0.05

# Estimated transaction cost in quote token (for net profit calculation)
TX_COST_IN_QUOTE=0.0002

# ─── Logging ──────────────────────────────────────────────────────────────────
# Log level: error | warn | info | debug
LOG_LEVEL=info

# Whether to save logs to files in logs/ directory (true/false)
LOG_TO_FILE=true

# ─── UI ───────────────────────────────────────────────────────────────────────
# Maximum number of opportunities to show in the CLI table
MAX_OPPORTUNITIES_DISPLAY=15

# Whether to show slippage column in the table (true/false)
SHOW_SLIPPAGE=true

# ─── Advanced Settings ────────────────────────────────────────────────────────
# Maximum number of pools to discover and monitor
MAX_POOLS_TO_MONITOR=50

# Number of RPC retry attempts on failure
RPC_RETRIES=3

# Initial delay between RPC retries (ms)
RPC_RETRY_DELAY_MS=1000