# ─── Solana RPC ───────────────────────────────────────────────────────────────
# A private RPC (Helius, QuickNode, Alchemy) is REQUIRED for stable operation.
# Public endpoints block getProgramAccounts and will fail on pool discovery.
# Helius free tier: https://helius.dev
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY_HERE

# ─── Tokens ───────────────────────────────────────────────────────────────────
# Base58 mint addresses of the token pair to monitor.
# Defaults below: Wrapped SOL / USDC
MINT_A=So11111111111111111111111111111111111111112
MINT_B=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Quote token used to measure profit and trade size (usually = MINT_B).
QUOTE_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ─── Arbitrage ────────────────────────────────────────────────────────────────
# How often to refresh pool reserves, in milliseconds (min: 500).
POLLING_INTERVAL_MS=2000

# Minimum net profit required to surface an opportunity (in quote token units).
# Example: 0.01 means at least $0.01 profit for a USDC quote token.
MIN_PROFIT_THRESHOLD=0.01

# Simulated trade size in quote token units (e.g., 100 = $100 USDC).
TRADE_SIZE=100

# Maximum allowed slippage per swap leg as a decimal (0.05 = 5%).
MAX_SLIPPAGE_PERCENT=0.05

# Estimated Solana transaction fee in quote token units.
# ~0.000005 SOL ≈ $0.0002 at $40/SOL. Adjust to current SOL price.
TX_COST_IN_QUOTE=0.0002

# ─── Logging ──────────────────────────────────────────────────────────────────
# Console + file log verbosity: error | warn | info | http | debug
LOG_LEVEL=info